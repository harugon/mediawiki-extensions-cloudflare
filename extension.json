{
	"name": "Cloudflare",
	"version": "0.3.0",
	"author": [
		"harugon"
	],
	"url": "https://github.com/harugon/mediawiki-extensions-cloudflare",
	"descriptionmsg": "cloudflare-desc",
	"license-name": "MIT",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"platform": {
			"php": ">= 8.0"
		}
	},
	"MessagesDirs": {
		"Cloudflare": [
			"i18n"
		]
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\Cloudflare\\HookHandler",
			"services": [ "MainConfig","CloudflareAPIRequester","TitleFactory"]
		}
	},
	"Hooks": {
		"LocalFilePurgeThumbnails": "main",
		"PageSaveComplete":"main",
		"PageMoveComplete":"main",
		"PageDeleteComplete":"main",
		"ArticlePurge": "main"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Cloudflare\\": "includes/"
	},
	"ConfigRegistry": {
		"cloudflare": "GlobalVarConfig::newInstance"
	},
	"config": {
		"CloudflareAPIToken": {
			"description": "Cloudflare API Token",
			"public": false,
			"value": false
		},
		"CloudflareZoneID": {
			"description": "Cloudflare Zone ID",
			"public": false,
			"value": false
		},
		"CloudflarePurgePage": {
			"description": "Purge a page from cache",
			"public": true,
			"value": false
		},
		"CloudflarePurgeFile": {
			"description": "Purge a File from cache",
			"public": true,
			"value": true
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"manifest_version": 2
}
